{
  "manifest_version": 3,
  "name": "ManyVids Divest",
  "version": "1.0.0",
  "description": "Download your ManyVids catalogue with metadata export",
  "permissions": [
    "tabs",
    "downloads",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.manyvids.com/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open ManyVids Divest",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["dashboard.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
